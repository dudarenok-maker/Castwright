{
  "name": "audiobook-generator",
  "version": "1.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "powershell -ExecutionPolicy Bypass -NoProfile -File scripts/start-app.ps1",
    "stop": "powershell -ExecutionPolicy Bypass -NoProfile -File scripts/stop-app.ps1",
    "start:prod": "node scripts/start-app-prod.mjs",
    "stop:prod": "node scripts/stop-app.mjs",
    "predev": "node scripts/preflight-ffmpeg.cjs",
    "dev": "concurrently -k -n frontend,server -c blue,magenta \"npm:dev:frontend\" \"npm:dev:server\"",
    "dev:frontend": "vite",
    "dev:server": "npm --prefix server run dev",
    "tts:sidecar": "powershell -ExecutionPolicy Bypass -File server/tts-sidecar/start.ps1",
    "build": "tsc -b && vite build && npm --prefix server run build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && npm --prefix server run typecheck",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "npm --prefix server run test",
    "test:scripts": "node scripts/run-powershell.mjs scripts/tests/run.ps1",
    "test:sidecar": "node scripts/run-powershell.mjs server/tts-sidecar/run-tests.ps1",
    "test:hooks": "node scripts/run-hooks-tests.mjs",
    "test:e2e": "playwright test",
    "test:a11y": "vitest run src/test/a11y.test.tsx",
    "test:fast": "npm run test:hooks && npm run test && npm run test:server",
    "test:all": "npm run test:hooks && npm run test && npm run test:server && npm run test:scripts && npm run test:sidecar",
    "verify": "node scripts/verify-cache.mjs",
    "verify:quick": "npm run test:all",
    "verify:fast": "node scripts/verify-cache.mjs --steps test:hooks,test,test:server",
    "openapi:types": "openapi-typescript ./openapi.yaml -o ./src/lib/api-types.ts",
    "reconcile-cast": "powershell -ExecutionPolicy Bypass -NoProfile -File scripts/reconcile-broken-cast.ps1",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@reduxjs/toolkit": "^2.2.0",
    "@types/qrcode": "^1.5.6",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.26.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.0",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "jest-axe": "^9.0.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.0.0",
    "postcss": "^8.4.45",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^2.1.9"
  }
}
