{
  "name": "audiobook-generator-server",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --include=.env src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p .",
    "pretest": "node ../scripts/preflight-ffmpeg.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^2.0.1",
    "@lingo-reader/mobi-parser": "^0.4.6",
    "@types/yazl": "^3.3.1",
    "epub2": "^3.0.2",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "sharp": "^0.34.5",
    "yazl": "^3.3.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
