{
  "name": "castwright-server",
  "version": "1.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --include=.env src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p .",
    "pretest": "node ../scripts/preflight-ffmpeg.cjs",
    "test": "vitest run",
    "test:slow": "vitest run --config vitest.config.slow.ts",
    "test:golden": "vitest run --config vitest.config.golden.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@lingo-reader/mobi-parser": "^0.4.6",
    "@types/yazl": "^3.3.1",
    "epub2": "^3.0.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "multer": "^2.1.1",
    "nanoid": "^5.0.7",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.35.1",
    "undici": "^8.3.0",
    "yauzl": "^3.3.0",
    "yazl": "^3.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "@types/yauzl": "^3.3.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.2",
    "typescript": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
