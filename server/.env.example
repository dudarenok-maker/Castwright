# Analysis backend selector.
#   local  (default): local Ollama daemon. Default model qwen3.5:4b — small
#                     enough (~3 GB VRAM) to stay resident across the
#                     analysis loop without crowding XTTS. Bigger models
#                     (qwen3.5:9b, llama3.1:8b) work too but unload after
#                     each call by design (see RESIDENT_MODELS in
#                     server/src/analyzer/ollama.ts).
#                     Auto-falls back to Gemini ONLY when the daemon is
#                     unreachable (ECONNREFUSED / ENOTFOUND / pre-first-byte
#                     abort). Errors from a running daemon hard-fail — by
#                     design, so a misbehaving local model doesn't silently
#                     burn Gemini quota.
#   gemini:           free-tier Gemini API direct (no local daemon).
ANALYZER=local

# Local Ollama daemon. Install Ollama for Windows, then `ollama pull qwen3.5:4b`
# (or 9b/llama for the heavier picks). The Ollama *model tag* is picked in the
# UI under Account → Defaults for new books → Analysis model (it doubles as
# the Ollama tag when it has Ollama shape — i.e. contains ':'). OLLAMA_MODEL
# below is only consulted as a last-resort fallback (no UI pick, no Ollama-
# shape default).
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b

# Optional. Required when ANALYZER=gemini; otherwise acts as the automatic
# fallback when ANALYZER=local and Ollama is unreachable. Get a free key at
# https://aistudio.google.com/.
#
# Resolution chain (plan 49): env var wins, then the UI-managed value saved
# from Account -> Server configuration -> Gemini API key (lives in
# server/user-settings.json, gitignored, plaintext, same trust model as
# this .env). Setting it here is the CI / power-user path; the UI is the
# recommended deployer path.
GEMINI_API_KEY=

# Gemini model used directly (ANALYZER=gemini) or as fallback (ANALYZER=local
# without Ollama). Defaults to gemma-4-31b-it (separate free-tier bucket from
# gemini-*; lower daily-hit risk for per-chapter stage 2). Override here to
# pin a different model for the local server.
GEMINI_MODEL=gemma-4-31b-it

# Gemini voice-style persona generator (plan 108). The model used to design
# each cast member's natural-language voice persona (one Gemini call per
# character, from their profile + dialogue evidence). Pinned to
# gemini-3.1-flash-lite (its own free-tier RPD bucket); override here for
# triage. Routes through the same per-model rate limiter as the analyzer.
# VOICE_STYLE_MODEL=gemini-3.1-flash-lite

# Pipelined two-model analyzer (plan 88). Set both ANALYZER_PHASE0_MODEL
# and ANALYZER_PHASE1_MODEL to drive Phase 0 (cast detection) and Phase 1
# (sentence attribution) with DIFFERENT models — typically Gemma for
# cast (anchors the roster) and Gemini Flash for attribution (faster on
# the heavier per-sentence output). The two analyzers hit independent
# rate-limit buckets, so quota is effectively doubled compared to a
# single-model run.
#
# When neither var is set, the legacy single-model ANALYZER=… path is
# preserved verbatim (regression contract). See docs/features/88-analyzer-
# per-phase-model.md for the back-pressure semantics and the
# acceptance walkthrough.
# ANALYZER_PHASE0_MODEL=gemma-4-31b-it
# ANALYZER_PHASE1_MODEL=gemini-3.1-flash-lite

# Minimum number of Phase 0 chapters Gemma must have completed ahead of
# any Phase 1 chapter Gemini is about to dispatch. The user's "keep 10
# chapters between them" requirement: Phase 1 chapter K dispatches only
# when Phase 0's watermark reaches K + ANALYZER_PHASE1_MIN_LAG_CHAPTERS.
# Set to 0 to release the lag entirely (pipelining still happens). The
# default 10 covers the typical case — major characters appear in the
# first 10 chapters of most books, so by the time Gemini starts chapter
# 0 it's working against a ~10-chapter-thick roster.
# ANALYZER_PHASE1_MIN_LAG_CHAPTERS=10

# Per-model rate-limit overrides for the analyzer. The server tracks RPM
# (requests/minute), TPM (input tokens/minute), and RPD (requests/day) per
# model and waits proactively when any cap would be breached — including
# during retries — so 429/500 storms from hitting limits don't happen.
# Built-in defaults match Google's free-tier values (pulled from
# aistudio.google.com/app/rate-limit on 2026-05-16):
#   gemini-3.1-flash-lite:  15 RPM, 250000 TPM, 500 RPD
#   gemini-3-flash-preview:  5 RPM, 250000 TPM,  20 RPD
#   gemini-2.5-flash:        5 RPM, 250000 TPM,  20 RPD
#   gemma-4-31b-it:         15 RPM, Unlimited,  1500 RPD
#   gemma-4-26b-a4b-it:     15 RPM, Unlimited,  1500 RPD
# Override in env using GEMINI_RPM_<slug>=N where <slug> is the model id
# uppercased with non-alphanumeric replaced by `_`. Example:
#   GEMINI_RPM_GEMINI_3_1_FLASH_LITE=20
#   GEMINI_TPM_GEMINI_3_1_FLASH_LITE=400000
#   GEMINI_RPD_GEMINI_3_1_FLASH_LITE=1000
# Set TPM to `unlimited` for models with no per-minute token cap.

# GPU arbitration — max concurrent GPU ops (analyzer + sidecar combined). Bump only after measuring VRAM headroom.
GPU_CONCURRENCY=99

# GPU arbitration — total VRAM token budget for the weighted semaphore. Each GPU op
# takes tokens equal to its engine's VRAM weight (kokoro 1, qwen 1, coqui 3, gemini 0,
# analyzer 4 — provisional; see server/src/tts/engine-vram-cost.ts + BACKLOG #39), and
# the semaphore admits a combination only when the summed cost fits this budget. On an
# 8 GB box, 4 lets Kokoro+Qwen (1+1) run together while Coqui (3) or the analyzer (4)
# serialise heavier work. When UNSET, the budget falls back to GPU_CONCURRENCY (default 1)
# and every op costs 1, so behaviour is byte-identical to the old count semaphore.
# NOTE (plan 113): the Qwen model forward is serialised per-engine (it is not
# thread-safe), so budget>1 gives NO extra SAME-engine Qwen throughput — it only lets
# DIFFERENT engines overlap (Kokoro narrator + Qwen dialogue). Qwen's throughput lever
# is batching (QWEN_BATCH_SIZE below), not this.
# GPU_VRAM_BUDGET=4

# Generation queue concurrency — how many chapters the queue synthesises at once
# (renamed from the retired GEN_CHAPTER_CONCURRENCY). GEN_WORKERS (env) is the
# deploy knob and takes PRECEDENCE over the per-user `generationWorkers` account
# setting; resolution order (server/src/workspace/user-settings.ts):
# GEN_WORKERS env -> account setting -> default 1. Queue concurrency ONLY —
# actual GPU work is bounded by the semaphore above, so raising it never risks
# VRAM OOM.
#
# Set 1 for a single Qwen-heavy book: the Qwen forward is serialised (plan 113),
# so a 2nd same-book worker can't parallelise — it just contends on the lock and
# ~DOUBLES per-chapter RTF (1.28 -> 2.00 measured) for only ~+13% aggregate
# (2026-05-28; see docs/tts-performance.md). Keep 2 only for cross-engine
# overlap (Kokoro narrator + Qwen dialogue). Restart to apply.
# GEN_WORKERS=1

# Qwen batching (plans 113/128/136) — throughput vs VRAM, Qwen-only
# (Coqui/Kokoro/Gemini have no batch API and stay one-per-call). The model runs
# ONE batched generate_voice_clone forward per decode step instead of N, so a
# Qwen-heavy chapter renders faster. Per-sentence audio is byte-IDENTICAL at any
# setting (each sentence is an independent sequence with its own voice prompt —
# no shared context, no drift), so these trade throughput vs VRAM, never quality.
# All read once at startup — restart to apply. A real CUDA OOM surfaces as a
# sidecar 500/503: lower the budget first, then the cap. (The old "tensor a (8)
# must match b (7)" 500 was a concurrent-batch race fixed in plan 113, NOT OOM.)
#
# The three knobs work together; the values shown ARE the shipped defaults (the
# adopted 32/3600 config) — uncomment only to override:
#   QWEN_BATCH_SIZE         hard width cap (max sentences/batch). 1 = batching off.
#   QWEN_BATCH_TOKEN_BUDGET variable width: fill each batch while width×maxLen ≤
#                           budget (normalised chars) → short/dialogue batches go
#                           wide, long ones stay narrow. 0 = exact fixed-width
#                           QWEN_BATCH_SIZE slicing (the kill-switch).
#   QWEN_BATCH_BUCKET       sort batchable groups by length first (default on);
#                           the token budget relies on it. 0 = index-order.
# Micro-bench (RTX 4070, single stream, docs/tts-performance.md): fixed B=8 → RTF
# ~1.28, B=16 → ~0.80. 32/3600 adopted after the 2026-05-30 live A/B; cap 64 was
# a wash-to-worse on dialogue (padding waste). Pair with GEN_WORKERS=1 so peak
# VRAM stays bounded (≈ same-engine-concurrency × cap).
# QWEN_BATCH_SIZE=32
# QWEN_BATCH_TOKEN_BUDGET=3600
# QWEN_BATCH_BUCKET=1

# Qwen attention backend (sidecar env; inherited by the server-spawned sidecar).
# Default sdpa. flash_attention_2 needs the flash-attn wheel (install-qwen3.mjs
# --flash-attn, plan 115) and benchmarked ≈ SDPA on the 4070 (TTS is decode-bound,
# not prefill-bound), so it is not worth flipping. See server/tts-sidecar/README.md.
# QWEN_ATTN_IMPL=sdpa

# Qwen VoiceDesign idle TTL (seconds; sidecar env). The heavy transient
# VoiceDesign 1.7B model is loaded during voice design and kept WARM so a
# cast-review session's back-to-back designs don't reload it each time. A
# background watchdog frees it (reclaiming ~4–5 GB) once it has been idle this
# long since the last design; a real /synthesize also frees it immediately
# (leaving design mode → generation). Default 120. Values below 5 fall back to
# the default to avoid reload thrash.
# QWEN_DESIGN_IDLE_TTL=120

# Variable-shape host-memory leak probe (sidecar env; side-11). The Qwen
# generation forward leaks committed-private host RAM monotonically because every
# sentence is a different length → a new native per-shape workspace that's never
# freed (committed climbs unbounded on variable-length generation, holds flat on
# fixed shapes, CUDA stays flat — pytorch/pytorch #32596). The process-recycle
# (SIDECAR_RESTART_MB) bounds it but interrupts long runs. This knob disables
# torch MKLDNN, which kills the suspected CPU per-shape workspace at a small
# CPU-op cost. Default 0 (OFF) — opt-in until a live A/B (scripts/bench-tts.py
# --mem-sample, run with it off then on) proves the committed slope flattens.
# CPU-only flag: a no-op if the leak turns out to be on the CUDA allocator side.
# SIDECAR_DISABLE_MKLDNN=0

# Soft recycle at the chapter boundary (sidecar env; side-11 item 2). The same
# variable-shape host leak forces a process-recycle; the HARD ceiling
# (SIDECAR_RESTART_MB) fires LATE — after RTF has degraded — and can drain
# mid-chapter. This SOFT threshold sets `recycle_pending` in /health once
# committed-private crosses it (WITHOUT exiting); the generation worker then
# triggers a CLEAN recycle (drain → respawn) at the next chapter boundary —
# earlier and never mid-chapter. Set it a few GB BELOW SIDECAR_RESTART_MB.
# Default 0 (OFF) — opt-in until a live GPU run tunes it (same convention as
# SIDECAR_DISABLE_MKLDNN). The hard SIDECAR_RESTART_MB watchdog stays armed as
# the untouched backstop. Example: a box whose proven committed ceiling is ~35GB
# would set the hard ceiling to 35000 and recycle softly at 30000.
#
# TUNING NOTE (2026-06-02): set the SOFT threshold with HEADROOM below the
# observed per-batch committed PEAK, not just below the hard ceiling. On a 64 GB
# box a run leaked to a committed peak of ~39.6 GB while SIDECAR_RECYCLE_SOFT_MB
# was 40500 — it grazed the threshold for minutes and never recycled, then a
# chapter stalled. The watchdog now samples committed every 15s (not 60s) so
# transient spikes are observed, but the threshold still has to sit below the
# spikes you want to act on. Recommended on that box: ~34000 soft / 46000 hard.
# SIDECAR_RECYCLE_SOFT_MB=34000
# SIDECAR_RESTART_MB=46000

# Adopt-fitness ceiling (server env; 2026-06-02 "stuck after restart"). On
# startup the server reuses an already-listening sidecar on :9000 — but a
# restart that adopts a LEAK-SATURATED orphan (committed ~26 GB vs a ~10 GB fresh
# load) bolts a fresh server onto a dying process and wedges. The server now
# REFUSES to adopt a sidecar whose /health committed_mb is at/above this ceiling
# (or that reports recycle_pending), killing + respawning a clean one instead.
# Default 20000 MB; `0` disables the committed check (recycle_pending still gates).
# SIDECAR_ADOPT_MAX_COMMITTED_MB=20000
#
# How often the supervisor /health-polls an ADOPTED sidecar for fitness (ms), on
# top of the cheap per-tick TCP disappearance probe — so an adopted sidecar that
# stays up but crosses the ceiling / flips recycle_pending is replaced, not just
# one that exits. Default 20000.
# SIDECAR_ADOPTED_HEALTH_POLL_MS=20000

# Per-chapter no-progress watchdog (server env; 2026-06-02 the drowning bell ch52).
# A chapter that makes NO forward progress — no group/batch completes AND no
# assembly milestone lands — for this long is aborted and recorded as a
# generationError, instead of hanging the queue forever with no breadcrumb. This
# is the whole-chapter catch-all that ALSO covers the post-synth assembly phase
# (encode / ffmpeg loudnorm / disk), which has no per-call ceiling. Generous
# default (720000 = 12 min) — above the longest legitimate batch (~5 min) and the
# 10-min per-call SIDECAR_CALL_TIMEOUT_MS. `0` disables.
# CHAPTER_NO_PROGRESS_MS=720000

# Pre-assembly per-sentence QA gate (server env; segment-qa.ts). After a chapter's
# sentences synthesise but BEFORE they're concatenated, each sentence's PCM is
# checked for dead/near-silence, a long internal silence run, and duration drift
# (vs the text-predicted length). A sentence that fails is RE-RECORDED in place
# up to SEG_QA_MAX_RERECORDS times (default 2; `0` disables the gate entirely,
# byte-identical to pre-gate). After the retries the best take is kept and the
# segment is flagged `suspect` — the chapter still completes. The same checks
# back the audio-qa-repair route for already-rendered chapters. Thresholds:
#   SEG_QA_SILENCE_RMS               mean RMS at/below → dead (default 0.003)
#   SEG_QA_NOISE_FLOOR               |sample| below → silent, for the run scan (0.01)
#   SEG_QA_MAX_INTERNAL_SILENCE_SEC  longest silent run above → gap (default 1.5)
#   SEG_QA_MIN_RATIO                 durationSec/expectedSec below → truncated (0.4)
#   SEG_QA_MAX_RATIO                 durationSec/expectedSec above → runaway (2.5)
# SEG_QA_MAX_RERECORDS=2

# ASR content-QA (srv-31; server env + sidecar Whisper). The signal gate above
# can't see a fluent, full-length, full-loudness sentence that says the WRONG
# words. With this ON, each sentence is transcribed (faster-whisper in the
# sidecar) and word-error-rated against its manuscript text; a `drift` verdict is
# re-recorded (best-of-N by WER) and a still-drifting one is flagged `asrSuspect`
# (shipped, never blocks). OFF by default — the Whisper dep stays dormant until
# SEG_ASR_ENABLED. Server knobs:
#   SEG_ASR_ENABLED        1/true/yes/on to enable the pass (default off)
#   SEG_ASR_MAX_RERECORDS  drift re-records, best-of-N (default 2; 0 = flag only)
#   SEG_ASR_SAMPLE_EVERY   transcribe 1-in-N sentences (default 1 = every sentence)
# WER-policy thresholds (segment-asr-qa.ts):
#   SEG_ASR_MAX_WER          word-error-rate above → drift (default 0.4)
#   SEG_ASR_MAX_DELETION_RUN consecutive missing words above → truncation (default 4)
#   SEG_ASR_MIN_CHARS        sentences shorter aren't scored (default 12)
#   SEG_ASR_MAX_COMPRESSION  Whisper compression ratio above → loop/drift (default 2.4)
#   SEG_ASR_MIN_AVG_LOGPROB  below → transcript untrusted → inconclusive (default -1.0)
#   SEG_ASR_MAX_NO_SPEECH    above → transcript untrusted → inconclusive (default 0.6)
# Whisper placement (sidecar env; read by the Python sidecar process):
#   ASR_DEVICE   cpu (default; zero VRAM) | cuda (opt-in; ~150-400 MB on tiny/base)
#   ASR_MODEL    faster-whisper model (default base; cap at base on an 8 GB card)
#   ASR_COMPUTE_TYPE  int8 (cpu) / int8_float16 (cuda) — override for a roomier card
#   ASR_IDLE_TTL      seconds idle before the sidecar frees the model (default 120)
#   ASR_CONCURRENCY   sidecar transcribe thread-pool width (default 2)
# Back-catalog: `npx tsx scripts/audit-audio-asr-drift.mts` scans existing books
# (read-only) and reports content drift per book/chapter/engine.
# SEG_ASR_ENABLED=0

# Stage-2 attribution coverage guard (server env; analyzer/stage2-coverage.ts).
# The per-chapter attribution model occasionally loop-and-truncates — it re-emits
# a span of sentences and stops early, so the chapter is BOTH duplicated and
# missing its tail, yet schema-valid (the 2026-06-05 The Drowning Bell ch12/ch18 bug).
# After each stage-2 chapter, the attributed sentences are validated against the
# source prose (coverage ratio + duplicated-block detection); a failing chapter
# is RE-ANALYSED up to STAGE2_COVERAGE_RETRIES times (default 2; `0` disables the
# guard). If it never passes, the least-bad take is kept and the chapter is added
# to failedChapterIds (Retry button in the analysing view). The same detector
# backs `scripts/audit-stage2-coverage.mts` (audit existing books). Thresholds:
#   STAGE2_MIN_COVERAGE   attributed/source word ratio below → truncated (default 0.6)
#   STAGE2_MAX_COVERAGE   ratio above → likely a loop (default 1.6)
#   STAGE2_MIN_DUP_RUN    contiguous duplicated-sentence run to flag (default 4)
# STAGE2_COVERAGE_RETRIES=2

# Large-chapter handling (#528). Stage-2 emits one JSON entry per sentence, so a
# very large chapter (e.g. The Drowning Bell ch19, 507 sentences) needs more output
# tokens than the model's cap and the response truncates mid-JSON — pre-fix this
# threw and the client saw a bare ECONNRESET. Two layers now prevent it:
#  1. Both engines DETECT truncation (Gemini finishReason=MAX_TOKENS, Ollama
#     done_reason=length) and raise a loud, classified error instead of returning
#     a corrupt buffer. The explicit output caps make the limit visible/tunable:
#       ANALYZER_MAX_OUTPUT_TOKENS  Gemini maxOutputTokens (default 8192)
#       ANALYZER_NUM_PREDICT        Ollama num_predict (default -1 = until ctx full)
#  2. A chapter whose prose exceeds STAGE2_CHUNK_CHAR_BUDGET is transparently
#     split into paragraph-bounded sections, each attributed under the cap and
#     stitched back together (a within-budget chapter is one call, unchanged). A
#     section that still truncates is adaptively re-split. Lower the budget if a
#     model with a smaller cap keeps truncating.
#       STAGE2_CHUNK_CHAR_BUDGET    chars per attribution section (default 9000)
# ANALYZER_MAX_OUTPUT_TOKENS=8192
# ANALYZER_NUM_PREDICT=-1
# STAGE2_CHUNK_CHAR_BUDGET=9000

# VRAM-keyed recycle (sidecar env; plan 159). The host knobs above watch
# committed RAM; these watch RESERVED VRAM, which is a different pressure. A Qwen
# model reload that doesn't free the prior copy (or long-run allocator
# fragmentation) creeps the reserved pool past the physical card; on Windows
# (torch has no expandable_segments) the overflow spills into the NVIDIA sysmem
# fallback and the GPU thrashes (RTF collapse / stall) — the 2026-06-01 reload
# spill. These set the SAME `recycle_pending` flag as the host soft-recycle (so
# the boundary recycle fires identically) and, at the hard ceiling, self-exit so
# the supervisor respawns a fresh CUDA context — the only thing that resets a
# spilled/fragmented pool. Both default to a fraction of the device's total VRAM
# (soft 90%, hard 98%), so leaving them unset auto-scales to the card; override
# with absolute MB. 0 disables. (NB: also disable the NVCP sysmem fallback for
# python.exe — see server/tts-sidecar/README.md — so a true over-card allocation
# OOMs cleanly instead of thrashing.)
# SIDECAR_VRAM_RECYCLE_SOFT_MB=7200
# SIDECAR_VRAM_RESTART_MB=7900

# CUDA caching-allocator tuning (sidecar env). Curbs the reserved-pool
# fragmentation that drives the spill above. Read by torch at import, so it must
# be in the environment BEFORE the sidecar starts (it inherits the server's env;
# a running sidecar must be restarted to pick up a change). expandable_segments
# is unsupported on Windows — do NOT set it. Recommended:
# PYTORCH_CUDA_ALLOC_CONF=garbage_collection_threshold:0.8,max_split_size_mb:256

# ---------------------------------------------------------------------------
# TTS. Provider is now chosen per-request by the modelKey the UI sends.
# Local engines (coqui-*, piper-*, kokoro-*) hit the sidecar at LOCAL_TTS_URL.
# Gemini keys hit Google's API directly; GEMINI_API_KEY is required only when
# a Gemini modelKey is actually picked in the UI.
LOCAL_TTS_URL=http://localhost:9000
GEMINI_TTS_MODEL_25=gemini-2.5-flash-preview-tts
GEMINI_TTS_MODEL_31=gemini-3.1-flash-preview-tts

# Sidecar runtime knobs. The defaults below assume an NVIDIA GPU is present —
# combined they take XTTS from RTF ~3× (CPU) to ~0.15× on a modern card.
# Leave commented out for CPU-only boxes; the sidecar auto-detects and forces
# fp16/deepspeed OFF when device resolves to cpu.
# See server/tts-sidecar/README.md "GPU install" for the PyTorch CUDA wheel.
# COQUI_DEVICE=cuda
# COQUI_HALF=1
# DeepSpeed needs the standalone CUDA Toolkit (with nvcc) at install time on
# Windows; the runtime libs in the torch wheel aren't enough. Default to 0
# and treat DeepSpeed as opt-in — see server/tts-sidecar/README.md.
# COQUI_DEEPSPEED=0

# Eager-preload XTTS at sidecar startup. Default is 0 (lazy) — the sidecar
# port comes up in ~2s with no model loaded, and the in-app Load button on
# the Generate / Analysing screen warms XTTS on demand. Set to 1 to restore
# the old behaviour where the sidecar blocks startup on a full model load
# (~30-60s). The button still works either way; preload just controls
# whether the model is already resident when the user lands on the screen.
# PRELOAD_COQUI=0

# Eager-preload Kokoro at sidecar startup. Default is 1 (eager) — Kokoro is
# cheap to keep resident (~1 GB VRAM, ~1s load) and is the default TTS engine.
# Set to 0 if Qwen is your main engine and you want the ~1 GB VRAM back;
# Kokoro then warms on demand on the first synth that needs it (or via the
# POST /load endpoint). The Node server propagates this from the account-level
# "Eager-load Kokoro at startup" toggle when it auto-spawns the sidecar.
# PRELOAD_KOKORO=1

# Optional. Defaults to 8080.
# PORT=8080

# Optional (srv-19). Network interface the plain-HTTP server binds to.
# Defaults to 127.0.0.1 (loopback only) so the unauthenticated API + the
# /workspace static mount aren't reachable from other machines on the LAN.
# Set 0.0.0.0 to expose plain HTTP on all interfaces (power users; the
# opt-in `npm run start:lan` HTTPS flow already binds all interfaces).
# BIND_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# Audio loudness normalization (plan 71). Default ON — every newly-rendered
# chapter passes through a two-pass EBU R128 loudnorm filter targeting
# -16 LUFS / 11 LU / -1.5 dBTP (audiobook common). The measurement lands
# as a sibling <slug>.lufs.json next to the MP3 for the upcoming report-card
# UI (Wave 2 plan 77). Voice samples deliberately skip the pass.
# Set to "false" (literal string) to opt out per server install.
# AUDIO_LOUDNORM_ENABLED=true

# ---------------------------------------------------------------------------
# Workspace. The user-visible books/ tree lives here.
# Relative paths resolve against the server/ folder, so the default
# ../audiobook-workspace lands inside the repo at <repo>/audiobook-workspace/.
# It's gitignored. Absolute paths are honoured as-is — point at OneDrive,
# Dropbox, an external drive, etc., to keep the library outside the repo.
WORKSPACE_DIR=../audiobook-workspace

# ---------------------------------------------------------------------------
# User account settings file (plan 122). Account defaults (TTS engine,
# eagerLoadKokoro, analysis model, UI-saved Gemini key, …) are USER-scoped, so
# they live in ONE per-user file shared across every git checkout, defaulting
# to ~/.audiobook-generator/user-settings.json. This is why a save honours no
# matter which worktree the app launches from. A legacy per-checkout
# server/user-settings.json is migrated to that path automatically on first
# read. Override the location here (the server test bootstrap points it at a
# temp file so suites never touch real settings).
# USER_SETTINGS_FILE=C:\path\to\user-settings.json

# ---------------------------------------------------------------------------
# Companion-app APK (interim "third distribution method"). GET /api/companion/apk
# streams the packaged Android APK when one is present; the Listen-tab
# "Download .apk" button appears only when it is. The release zip bundles it at
# <release>/companion/castwright-companion.apk (build-release-zip stages it from
# COMPANION_APK_SRC at build time). Override the SERVED file here — absolute, or
# relative to the release root. Absent → the route 404s and the button hides.
# COMPANION_APK_PATH=C:\path\to\castwright-companion.apk

# >>> BEGIN generated config knobs (npm run config:sync) >>>

# ── LLM sampling parameters ──
# Sampling temperature for the first analysis attempt; lower values stay closer to the schema. [live]
OLLAMA_TEMPERATURE=0.2
# Temperature used on invalid-JSON retries to escape the failure path. [live]
OLLAMA_RETRY_TEMPERATURE=0.6
# Output-token cap for Ollama; -1 means predict until context window fills. [live]
ANALYZER_NUM_PREDICT=-1
# Per-request output-token cap for Gemini; set to match the free-tier ceiling. [live]
ANALYZER_MAX_OUTPUT_TOKENS=8192
# Context-window size handed to Ollama on every /api/chat call. Ollama keys the KV cache by (model, num_ctx), so warming with default 32768 and then changing it forces a re-load. Larger = more KV-cache VRAM; 32768 gives large/non-Latin chapters headroom (the stage-1/2 chunkers handle anything still over budget). Lower it if a bigger analyzer model strains the GPU. [live]
ANALYZER_NUM_CTX=32768
# Number of GPU layers for Ollama (999 = all layers). Ollama treats this as part of its load-time cache key alongside num_ctx, so mismatching values between /load and /api/chat can force redundant model swaps. Hardcoded today; registering this env name lifts it to a runtime knob. [live]
ANALYZER_NUM_GPU=999

# ── Analyzer chunking & truncation guards ──
# Maximum characters per stage-2 attribution chunk before the chapter is pre-emptively split. [live]
STAGE2_CHUNK_CHAR_BUDGET=9000
# Maximum characters per stage-1 cast-detection chunk before the chapter is split. For local engines the effective budget is derived (lowered) from Ollama num_ctx so a large or non-Latin chapter can never overflow the context window. [live]
STAGE1_CHUNK_CHAR_BUDGET=24000
# Attributed/source word-ratio floor below which a chapter is treated as truncated. [live]
STAGE2_MIN_COVERAGE=0.6
# Attributed/source word-ratio ceiling above which a chapter is treated as a repeat-loop. [live]
STAGE2_MAX_COVERAGE=1.6
# How many trailing source words must appear in the output for the chapter ending to be considered present. [live]
STAGE2_ENDING_TAIL_WORDS=8
# Smallest contiguous run of duplicated sentences (constant offset) flagged as a repeat-loop. [live]
STAGE2_MIN_DUP_RUN=4
# Number of re-runs when stage-2 coverage fails; 0 disables the guard. [live]
STAGE2_COVERAGE_RETRIES=2

# ── Analyzer models & endpoints ──
# "local" routes through the Ollama daemon (auto-falls back to Gemini when Ollama is unreachable and GEMINI_API_KEY is set). "gemini" always goes direct to the Gemini API. [live]
ANALYZER=local
# Base URL of the local Ollama daemon. [live]
OLLAMA_URL=http://localhost:11434
# Ollama model tag passed to /api/chat as the last-resort fallback. The Account-tab model picker takes precedence when it has Ollama tag shape (contains ":") [live]
OLLAMA_MODEL=qwen3.5:4b
# Gemini model used directly (ANALYZER=gemini) or as the Ollama-unreachable fallback (ANALYZER=local). Separate free-tier bucket from gemini-* models; lower daily-hit risk for per-chapter stage-2 analysis. [live]
GEMINI_MODEL=gemma-4-31b-it
# Gemini model used to design each cast member's natural-language voice persona (one call per character). Pinned to gemini-3.1-flash-lite (its own free-tier RPD bucket). Routes through the same per-model rate limiter as the main analyzer. [live]
VOICE_STYLE_MODEL=gemini-3.1-flash-lite
# "gemini" (default) designs each cast member's voice persona via the Gemini API — the locked quality choice. "local" routes persona generation through the local Ollama daemon so a no-Gemini install can still design voices. No silent cross-provider fallback: gemini with no key, or local with the daemon down, fails with a clear message. [live]
PERSONA_GEN_ENGINE=gemini
# Ollama model tag (e.g. qwen3.5:9b) used when persona generation engine is "local". Blank inherits the analyzer's resolved local model, so a box that has run local analysis needs no extra download. [live]
PERSONA_GEN_LOCAL_MODEL=
# When set, drives Phase 0 (cast detection) with this specific model while Phase 1 uses ANALYZER_PHASE1_MODEL. Leave empty to use the legacy single-model ANALYZER path for both phases. The two analyzers hit independent rate-limit buckets, so quota is effectively doubled. [live]
ANALYZER_PHASE0_MODEL=
# When set, drives Phase 1 (sentence attribution) with this specific model while Phase 0 uses ANALYZER_PHASE0_MODEL. Leave empty to use the legacy single-model ANALYZER path. [live]
ANALYZER_PHASE1_MODEL=
# Minimum number of Phase-0 chapters that must complete ahead of any Phase-1 dispatch. Ensures the roster is populated before attribution starts. Set to 0 to release the lag entirely. Only active when the per-phase model split is configured. [live]
ANALYZER_PHASE1_MIN_LAG_CHAPTERS=10
# How long Ollama holds a resident analyzer model in VRAM after a call (Ollama keep_alive: '5m', '1m', '0' to unload immediately, '-1' to pin). Applied to the RESIDENT_MODELS the analyzer keeps warm across the analysis loop; non-resident tags always unload immediately. '5m' bridges the gap between back-to-back chapter calls. Cross-engine eviction before a TTS/voice-design load is handled separately by the GPU load chokepoint (gpu.safeCoexistMb). [live]
ANALYZER_KEEP_ALIVE=5m

# ── Voice engine & device ──
# Which GPU stack the voice engines install + run on. "auto" (default) detects your hardware (NVIDIA → CUDA, AMD → ROCm/DirectML, Apple → Metal, else CPU). Pin "nvidia", "amd", or "cpu" to override. Changing this is NOT instant: it REBUILDS the Python environment (a different torch / ONNX-runtime install) and restarts the sidecar — your books and voices are untouched. AMD (ROCm/DirectML) is an experimental preview. [rebuild · high risk]
ACCELERATOR=auto
# Device for Coqui XTTS v2. "auto" lets the sidecar pick based on CUDA availability. Changing this requires a sidecar restart. [restart-sidecar · high risk]
COQUI_DEVICE=auto
# PyTorch device for Qwen3-TTS. "auto" (default) picks cuda:0 → mps (Apple Silicon) → cpu. Pin a specific GPU with "cuda:1", or force "cpu" / "mps". Changing this requires a sidecar restart. [restart-sidecar · high risk]
QWEN_DEVICE=auto
# "sdpa" is the PyTorch-native default and requires no extra deps. "flash_attention_2" needs the flash-attn wheel and benchmarks ≈ SDPA on the 4070 (TTS is decode-bound, not prefill-bound). Changing this requires a sidecar restart. [restart-sidecar · high risk]
QWEN_ATTN_IMPL=sdpa
# When true, the sidecar eagerly loads Coqui XTTS v2 at startup (~30-60 s, ~3 GB VRAM). When false (default), Coqui loads on demand via the in-app Load button. Changing this requires a sidecar restart. [restart-sidecar · high risk]
PRELOAD_COQUI=false
# When true (default), the sidecar eagerly loads Kokoro v1 at startup (~1 s, ~1 GB VRAM). When false, Kokoro warms on demand on the first synth that needs it. Turn off if Qwen is your main engine and you want the ~1 GB VRAM back. Changing this requires a sidecar restart. [restart-sidecar · high risk]
PRELOAD_KOKORO=true
# When true, the sidecar eagerly loads the Qwen Base synth model (~1.2 GB VRAM) at startup. When false (default), Qwen warms on demand via the in-app Load button. Only the Base model is eagerly warmed — the VoiceDesign model stays transient. Changing this requires a sidecar restart. [restart-sidecar · high risk]
PRELOAD_QWEN=false
# When true, the sidecar eagerly loads the Qwen 1.7B-Base model (~3.4 GB VRAM) at startup. Required for the anchored emotion-variant workflow (fs-55). When false (default), the 1.7B-Base warms on demand via the in-app Load button or POST /load {engine:"qwen", model:"1.7b"}. Changing this requires a sidecar restart. [restart-sidecar · high risk]
PRELOAD_QWEN_BASE17=false

# ── Voice batching & throughput ──
# Hard width cap: max sentences packed into one batched Qwen forward. Set to 1 to disable batching entirely (every Qwen sentence becomes its own call). Only affects Qwen — Coqui/Kokoro/Gemini always synth one-per-call. [restart-server]
QWEN_BATCH_SIZE=32
# Variable-width packing budget (normalised chars): keep adding sentences to a batch while (count+1) × maxLen ≤ budget. Short/dialogue batches pack wider; long batches stay narrow. Set to 0 for exact fixed-width slicing (QWEN_BATCH_SIZE only, kill-switch). [restart-server]
QWEN_BATCH_TOKEN_BUDGET=3600
# Hard width cap for the 1.7B Quality-tier specifically. Defaults to the same 32 as the 0.6B tier: once the 0.6B base is no longer co-resident (#1162 readiness-gate fix evicts the unused tier), a 1.7B render fits 32/3600 on an 8 GB card (measured peak ~5.7 GB, ~1.7 GB margin under the recycle line) at ~2× real-time. Lower this (and the budget below) on a smaller card if you hit a recycle storm. Only affects 1.7B groups. [restart-server]
QWEN_BATCH_SIZE_17B=32
# Variable-width packing budget (normalised chars) for the 1.7B Quality tier only. Defaults to the same 3600 as the 0.6B tier (safe on an 8 GB card post-#1162, since the unused 0.6B base no longer co-resides). Lower it on a smaller card if a 1.7B render trips the VRAM recycle. Set to 0 for exact fixed-width slicing on the 1.7B tier (tts.batch.size17b only). [restart-server]
QWEN_BATCH_TOKEN_BUDGET_17B=3600
# Sort batchable Qwen groups by normalised text length before slicing into batches, so similar-length sentences share a batch (less padding waste). Output is byte-identical regardless of batch composition. Set to false to revert to index order. [restart-server]
QWEN_BATCH_BUCKET=true
# Number of chapters the generation queue synthesises concurrently. Queue/synthesis concurrency only — the GPU semaphore is the VRAM guard. Default 1: the Qwen forward is serialised, so a 2nd same-book worker just contends on the lock, doubles per-chapter RTF, and accelerates the host-memory leak toward a recycle. Raise only on a multi-GPU / non-Qwen setup. [restart-server]
GEN_WORKERS=1

# ── Per-sentence QA gates ──
# How many times a suspect sentence is re-recorded before keeping the best take; 0 disables the gate. [live]
SEG_QA_MAX_RERECORDS=2
# Mean RMS at or below this value marks a segment as dead/near-silent. [live]
SEG_QA_SILENCE_RMS=0.003
# Normalised sample amplitude below which a sample is counted as silent for the internal-silence-run scan. [live]
SEG_QA_NOISE_FLOOR=0.01
# Longest contiguous near-silent run above this (seconds) marks a segment as suspect. [live]
SEG_QA_MAX_INTERNAL_SILENCE_SEC=1.5
# Duration/expected ratio below this marks a segment as truncated. [live]
SEG_QA_MIN_RATIO=0.4
# Duration/expected ratio above this marks a segment as runaway/garbled. [live]
SEG_QA_MAX_RATIO=2.5
# Enable Whisper-based content verification; requires the sidecar venv with faster-whisper installed. [live]
SEG_ASR_ENABLED=false
# Re-record budget for ASR drift; 0 = detect and flag only. [live]
SEG_ASR_MAX_RERECORDS=2
# Transcribe 1-in-N sentences; 1 = every sentence. [live]
SEG_ASR_SAMPLE_EVERY=1
# Word-error-rate above this threshold is flagged as content drift. [live]
SEG_ASR_MAX_WER=0.4
# Spanish-specific WER drift cap; defaults to the global ASR max WER until tuned on-box (#1084). [live]
SEG_ASR_MAX_WER_ES=0.4
# Russian-specific WER drift cap; defaults to the global ASR max WER until tuned on-box (#1084). [live]
SEG_ASR_MAX_WER_RU=0.4
# When on, each rendered line of a stochastic-engine character is embedded (ECAPA speaker model) and checked for acoustic match against the character's voice centroid, flagging misfires. Off by default. CPU (zero VRAM). [live]
SEG_SPK_ENABLED=false
# "cpu" (default) uses zero VRAM and never competes with synthesis. "cuda" runs the embed on the GPU — only worthwhile with GPU_VRAM_BUDGET >= 2 (at the default budget of 1 it serialises behind synth and is likely slower than cpu). Changing the device restarts the sidecar. [restart-sidecar]
SPK_DEVICE=cpu
# When on, severe voice-mismatch lines are re-rendered and replaced if the fresh take matches. Off until calibration confirms a low false-positive rate. [live]
SEG_SPK_AUTO_REPAIR=false
# Longest contiguous deletion run above this signals truncation/drop drift. [live]
SEG_ASR_MAX_DELETION_RUN=4
# Sentences shorter than this (trimmed chars) are not scored — too short for reliable WER. [live]
SEG_ASR_MIN_CHARS=12
# Whisper compression_ratio above this indicates a loop/repeat hallucination regardless of WER. [live]
SEG_ASR_MAX_COMPRESSION=2.4
# Whisper avg_logprob below this makes the transcript untrustworthy (inconclusive, not a re-record). [live]
SEG_ASR_MIN_AVG_LOGPROB=-1
# Whisper no_speech_prob above this makes the transcript untrustworthy (inconclusive). [live]
SEG_ASR_MAX_NO_SPEECH=0.6

# ── Audio loudness targets ──
# Enable EBU R128 two-pass loudness normalisation; disable to skip normalisation entirely. [live]
AUDIO_LOUDNORM_ENABLED=true
# Integrated loudness target in LUFS; -16 matches the Audible/ACX audiobook spec. [live]
AUDIO_LOUDNORM_TARGET=-16
# Target loudness range in LU; 11 is the audiobook community standard. [live]
AUDIO_LOUDNORM_LRA=11
# True-peak ceiling; -1.5 leaves headroom for codec inter-sample peaks. [live]
AUDIO_LOUDNORM_TP=-1.5

# ── GPU arbitration, memory & lifecycle ──
# Max concurrent GPU ops (analyzer + all TTS engines combined) when GPU_VRAM_BUDGET is not set. When GPU_VRAM_BUDGET IS set, this becomes the fallback budget. Bump only after measuring VRAM headroom. [restart-server · high risk]
GPU_CONCURRENCY=1
# Total VRAM token budget for the weighted semaphore. Each GPU op costs tokens equal to its engine weight (kokoro 1, qwen 1, coqui 3, analyzer 4, asr 1). The semaphore admits combinations only when their summed cost fits this budget. Set to 0 (default) to disable the VRAM budget and fall back to GPU_CONCURRENCY. On an 8 GB box, 4 lets Kokoro+Qwen (1+1) run together while Coqui (3) or the analyzer (4) serialise. [restart-server · high risk]
GPU_VRAM_BUDGET=0
# VRAM token cost for a Kokoro synthesis op. Lower values let Kokoro share the budget alongside other engines. Read live per-op via costForEngine(); changes take effect on the next synthesis without a restart. [live · high risk]
GPU_WEIGHT_KOKORO=1
# VRAM token cost for a Qwen synthesis op. Read live per-op via costForEngine(); changes take effect on the next synthesis without a restart. [live · high risk]
GPU_WEIGHT_QWEN=1
# VRAM token cost for a Coqui XTTS v2 synthesis op. Read live per-op via costForEngine(); changes take effect on the next synthesis without a restart. [live · high risk]
GPU_WEIGHT_COQUI=3
# VRAM token cost for an Ollama analyzer op. At the default budget of 4 the analyzer consumes the whole budget, serialising it against any TTS op. Read live per-op via costForEngine(); changes take effect on the next synthesis without a restart. [live · high risk]
GPU_WEIGHT_ANALYZER=4
# VRAM token cost for a Whisper ASR op. Only charged when ASR_DEVICE=cuda; the CPU-default path takes no token. Read live per-op via costForEngine(); changes take effect on the next transcription without a restart. [live · high risk]
GPU_WEIGHT_ASR=1
# VRAM token cost for a render-integrity ECAPA speaker-embed op. Only charged when SPK_DEVICE=cuda; the CPU-default path takes no token. Read live per-op via costForEngine(); changes take effect on the next embed without a restart. [live · high risk]
GPU_WEIGHT_SPK=1
# If detected GPU VRAM is below this, evict the resident Ollama analyzer before loading a sidecar TTS/voice-design model. 8 GB cards evict; 12/16 GB coexist. 0 = always evict. [live · high risk]
GPU_SAFE_COEXIST_MB=11000
# Seconds of voice-design inactivity before the watchdog frees the transient Qwen VoiceDesign 1.7B model (reclaiming ~4–5 GB VRAM). Values below 5 fall back to the default (120) to avoid reload thrash. A real /synthesize also frees it immediately. [restart-sidecar · high risk]
QWEN_DESIGN_IDLE_TTL=120
# Seconds of inactivity before the watchdog frees the resident Qwen 1.7B-Base model (reclaiming ~3.4 GB VRAM). It stays warm across back-to-back emotion-variant mints and 1.7B (Quality-tier) synths so a full-library re-mint runs in one pass without fragmenting the CUDA allocator (issue #1024); lower this to shrink the warm window on a small card. Values below 5 fall back to the default (120) to avoid reload thrash. [restart-sidecar · high risk]
QWEN_BASE17_IDLE_TTL=120
# Seconds of ASR inactivity before the sidecar frees the Whisper model. Mainly reclaims VRAM on ASR_DEVICE=cuda; on cpu it frees host RAM. Values below 5 fall back to the default (120) to avoid reload thrash. [restart-sidecar · high risk]
ASR_IDLE_TTL=120
# Seconds of speaker-embed inactivity before the sidecar frees the ECAPA model. Reclaims VRAM only on SPK_DEVICE=cuda (a no-op on cpu). Values below 5 fall back to the default (120) to avoid reload thrash. [restart-sidecar · high risk]
SPK_IDLE_TTL=120
# When true, sets torch.backends.mkldnn.enabled = False at model load to curb the variable-shape CPU host-RAM leak (pytorch#32596). CPU-only flag — a no-op if the leak is on the CUDA allocator side. Default off (opt-in until a live A/B proves the committed slope flattens). [restart-sidecar · high risk]
SIDECAR_DISABLE_MKLDNN=false
# Committed-private RAM (MB) at which the sidecar sets recycle_pending in /health, triggering a clean chapter-boundary recycle rather than a mid-chapter hard exit. 0 = disabled (default). Set a few GB below SIDECAR_RESTART_MB. [restart-sidecar · high risk]
SIDECAR_RECYCLE_SOFT_MB=0
# Committed-private RAM (MB) at which the sidecar self-exits so the supervisor respawns a fresh process (process recycling). 0 = auto (default): uses 70% of total physical RAM when psutil can read it, or disabled when it cannot. Override with an absolute MB value. [restart-sidecar · high risk]
SIDECAR_RESTART_MB=0
# Reserved VRAM (MB) at which the sidecar sets recycle_pending in /health. 0 = auto (default): uses 90% of device total VRAM when readable. Override with an absolute MB value to tune for your card. [restart-sidecar · high risk]
SIDECAR_VRAM_RECYCLE_SOFT_MB=0
# Reserved VRAM (MB) at which the sidecar self-exits so the supervisor respawns a fresh CUDA context (the only thing that resets a spilled/fragmented VRAM pool). 0 = auto (default): uses 98% of device total VRAM when readable. Override with an absolute MB value. [restart-sidecar · high risk]
SIDECAR_VRAM_RESTART_MB=0

# ── Gemini rate limits ──
# Requests-per-minute cap for gemma-4-31b-it. Override to adjust the free-tier limit (default 15 RPM from AI Studio 2026-05-16). The limiter waits proactively so no 429s are issued. [restart-server]
GEMINI_RPM_GEMMA_4_31B_IT=15
# Input-tokens-per-minute cap for gemma-4-31b-it. Set to 0 here to represent the free-tier "Unlimited" TPM — the limiter treats 0 as Infinity (no TPM gate). Override with a positive number to impose a local cap. [restart-server]
GEMINI_TPM_GEMMA_4_31B_IT=0
# Requests-per-day cap for gemma-4-31b-it. Default 1500 (free-tier from AI Studio 2026-05-16). The limiter raises DailyQuotaExhaustedError rather than firing a 429. [restart-server]
GEMINI_RPD_GEMMA_4_31B_IT=1500

# ── LAN access & device tokens ──
# How long a browser/device authorization stays valid before it must be re-paired. [live]
LAN_DEVICE_TTL_DAYS=30

# <<< END generated config knobs <<<

