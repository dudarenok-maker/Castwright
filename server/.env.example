# Analysis backend selector.
#   manual (default): writes a prompt to server/handoff/inbox/ and waits for
#                     the user to paste skill output into server/handoff/outbox/.
#   gemini:           calls the free-tier Gemini API directly using GEMINI_API_KEY.
ANALYZER=manual

# Required when ANALYZER=gemini. Get a free key at https://aistudio.google.com/.
GEMINI_API_KEY=

# Optional. Defaults to gemma-4-31b-it (separate free-tier bucket from
# gemini-*; lower daily-hit risk for per-chapter stage 2). Override here to
# pin a different model for the local server.
GEMINI_MODEL=gemma-4-31b-it

# ---------------------------------------------------------------------------
# TTS. Provider is now chosen per-request by the modelKey the UI sends.
# Local engines (coqui-*, piper-*, kokoro-*) hit the sidecar at LOCAL_TTS_URL.
# Gemini keys hit Google's API directly; GEMINI_API_KEY is required only when
# a Gemini modelKey is actually picked in the UI.
LOCAL_TTS_URL=http://localhost:9000
GEMINI_TTS_MODEL_25=gemini-2.5-flash-preview-tts
GEMINI_TTS_MODEL_31=gemini-3.1-flash-preview-tts

# Optional. Defaults to 8080.
# PORT=8080

# ---------------------------------------------------------------------------
# Workspace. The user-visible books/ tree lives here.
# Relative paths resolve against the server/ folder, so the default
# ../audiobook-workspace lands inside the repo at <repo>/audiobook-workspace/.
# It's gitignored. Absolute paths are honoured as-is — point at OneDrive,
# Dropbox, an external drive, etc., to keep the library outside the repo.
WORKSPACE_DIR=../audiobook-workspace
