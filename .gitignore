# Build artifacts
node_modules/
dist/
.vite/
*.tsbuildinfo
# RELEASE_NOTES.md is now a COMMITTED, maintained brand-voice multi-version
# history (fe-37) — served verbatim via GET /api/info and rendered at
# #/release-notes. It is no longer generated from the tag body; the GitHub
# release body comes from the tag annotation in release.yml instead.
# Interim companion-app distribution — the server's default APK drop location
# (GET /api/companion/apk). Bundled into the release zip at build time; a
# locally-dropped APK for testing must never be committed (it's a ~tens-of-MB
# binary, regenerated per app build). Override the path with COMPANION_APK_PATH.
/companion/

# Env
.env
.env.local
.env.*.local
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
.claude/
.claude-*
# Superpowers brainstorming visual-companion mockups (local-only scratch)
.superpowers/

# Brand assets + identity exploration + UI mockups — local-only documents.
# Not committed: the brand identity is "all rights reserved" and these are
# working/scratch artifacts. The app ships GENERATED assets in public/ (PNGs
# rendered from brand/*.svg via scripts/render-brand-pngs.mjs), which ARE
# committed — so removing these sources never breaks the build.
# `mockups/` is the home for any future brand/style/UI exploration work.
brand/
mockups/

# Marketing capture covers (local-only). Served by Vite at /marketing-covers/*
# during `npm run capture:marketing`; the source art lives in git-ignored
# brand/book-covers/. Regenerable, never committed (public/ otherwise ships).
public/marketing-covers/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Background-process PID files written by scripts\start-app.ps1
.run/

# Test output
coverage/

# Verify-cache (per-step input hashes for `npm run verify`; never committed).
.verify-cache.json
.verify-cache.json.tmp

# Playwright artefacts (browsers cached in %LOCALAPPDATA%, not the repo).
playwright-report/
test-results/
.playwright/

# Husky internals (hook scripts are tracked; staging dir is not)
.husky/_/

# Uploads dir (sandbox-only)
uploads/

# Server handoff runtime drops
server/handoff/inbox/*
server/handoff/outbox/*
server/handoff/cache/*
!server/handoff/inbox/.gitkeep
!server/handoff/outbox/.gitkeep
!server/handoff/cache/.gitkeep
server/dist/

# Per-user account defaults + non-secret env overrides. Auto-created on
# first GET /api/user/settings; holds display name, default models,
# analyzer mode, sidecar URL, workspace override. Belongs-to-the-user data.
server/user-settings.json

# Local TTS sidecar — Python venv + downloaded model weights stay local.
# Source files (main.py, requirements.txt, README.md, start.ps1) are tracked;
# everything below is build/runtime state only.
server/tts-sidecar/.venv/
server/tts-sidecar/models/
server/tts-sidecar/.coqui/
server/tts-sidecar/sample.*
# Kokoro v1 weights downloaded by scripts/install-kokoro.ps1 (~330 MB total).
server/tts-sidecar/voices/

# Python build/cache artefacts — match anywhere in the tree since the sidecar
# is currently the only Python in the repo and these are never wanted.
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*

# Server-generated TTS audio cache
server/audio/

# On-disk book workspace (manuscripts + .audiobook/ state + audio output).
# Lives at <repo>/audiobook-workspace/ by default; override via WORKSPACE_DIR.
# Belongs-to-the-user data — never sent to GitHub.
audiobook-workspace/
/audiobook-workspace/

# Local revert-safety backups of cast.json, written before a data-repair run
# (scripts/repair-series-reuse.mjs). Belongs-to-the-user data — local only,
# never committed; safe to delete once a repair is verified.
.cast-backups/

# Real-binary MOBI / AZW3 fixtures — generated by scripts/gen-parser-fixtures.mjs
# via Calibre's ebook-convert. Plan 60. Not committed because they require a
# per-developer Calibre install to regenerate; the EPUB + PDF fixtures (above)
# are checked in and the MOBI/AZW3 e2e cases skip cleanly when these are absent.
server/src/parsers/__fixtures__/sample.mobi
server/src/parsers/__fixtures__/sample.azw3

# Ad-hoc local repro / bisect scripts (and their scratch output) for one-off
# debugging — e.g. the Russian stage-2 under-production probes. Local only,
# never committed; also excluded from lint (see eslint.config.js).
server/repro-*.mts
server/repro-*.txt
server/roster.json
