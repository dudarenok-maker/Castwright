# Build artifacts
node_modules/
dist/
.vite/
*.tsbuildinfo

# Env
.env
.env.local
.env.*.local
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
.claude/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Background-process PID files written by scripts\start-app.ps1
.run/

# Test output
coverage/

# Husky internals (hook scripts are tracked; staging dir is not)
.husky/_/

# Uploads dir (sandbox-only)
uploads/

# Server handoff runtime drops
server/handoff/inbox/*
server/handoff/outbox/*
server/handoff/cache/*
!server/handoff/inbox/.gitkeep
!server/handoff/outbox/.gitkeep
!server/handoff/cache/.gitkeep
server/dist/

# Local TTS sidecar — Python venv + downloaded model weights stay local.
# Source files (main.py, requirements.txt, README.md, start.ps1) are tracked;
# everything below is build/runtime state only.
server/tts-sidecar/.venv/
server/tts-sidecar/models/
server/tts-sidecar/.coqui/
server/tts-sidecar/sample.*

# Python build/cache artefacts — match anywhere in the tree since the sidecar
# is currently the only Python in the repo and these are never wanted.
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*

# Server-generated TTS audio cache
server/audio/

# On-disk book workspace (manuscripts + .audiobook/ state + audio output).
# Lives at <repo>/audiobook-workspace/ by default; override via WORKSPACE_DIR.
# Belongs-to-the-user data — never sent to GitHub.
audiobook-workspace/
/audiobook-workspace/
